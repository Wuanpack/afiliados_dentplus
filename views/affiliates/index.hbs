
<div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2">
  <div>
    <h1 class="h3 mb-1">Afiliados</h1>
    <p class="text-muted mb-0 small">
      {{#if isAdmin}}Vista de administrador: todos los afiliados y usuarios.{{else}}Tus afiliados registrados.{{/if}}
    </p>
  </div>
  <a href="/affiliates/create" class="btn btn-primary">+ Nuevo afiliado</a>
</div>

{{#if affiliates.length}}
  <div class="card shadow-sm mb-4">
    <div class="table-responsive">
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>Nombre</th>
            <th>Email</th>
            <th>Membresía</th>
            <th>Descuento</th>
            {{#if isAdmin}}<th>Gestor</th>{{/if}}
            <th>Estado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          {{#each affiliates}}
            <tr class="{{#unless this.status}}table-secondary{{/unless}}">
              <td>{{this.id}}</td>
              <td>{{this.first_name}} {{this.last_name}}</td>
              <td>{{this.email}}</td>
              <td>{{capitalize this.membershipType.name}}</td>
              <td>{{formatPercent this.membershipType.discount}}</td>
              {{#if ../isAdmin}}<td class="small text-muted">{{this.user.email}}</td>{{/if}}
              <td>
                {{#if this.status}}<span class="badge bg-success">Activo</span>{{else}}<span class="badge bg-danger">Inactivo</span>{{/if}}
              </td>
              <td class="table-actions">
                <a href="/affiliates/{{this.id}}" class="btn btn-sm btn-outline-secondary">Ver</a>
                <a href="/affiliates/{{this.id}}/edit" class="btn btn-sm btn-outline-warning">Editar</a>
                {{#if this.status}}
                  <form action="/affiliates/{{this.id}}/deactivate" method="POST" class="d-inline" onsubmit="return confirm('¿Desactivar este afiliado?')" novalidate>
                    <button type="submit" class="btn btn-sm btn-outline-danger">Desactivar</button>
                  </form>
                {{else}}
                  <form action="/affiliates/{{this.id}}/activate" method="POST" class="d-inline" novalidate>
                    <button type="submit" class="btn btn-sm btn-outline-success">Activar</button>
                  </form>
                {{/if}}
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>
{{else}}
  <div class="alert alert-info">No hay afiliados todavía. <a href="/affiliates/create">Crea el primero</a>.</div>
{{/if}}

{{#if isAdmin}}
  <hr class="my-5">
  <h2 class="h4 mb-3">Usuarios del sistema</h2>
  {{#if users.length}}
    <div class="card shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th>#</th>
              <th>Email</th>
              <th>Rol</th>
              <th>Estado</th>
              <th>Alta</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            {{#each users}}
              <tr class="{{#unless this.status}}table-secondary{{/unless}}">
                <td>{{this.id}}</td>
                <td>{{this.email}}{{#if (eq this.id ../session.userId)}} <span class="badge bg-info text-dark">Tú</span>{{/if}}</td>
                <td><span class="badge {{roleBadgeClass this.role}}">{{this.role}}</span></td>
                <td>{{#if this.status}}<span class="badge bg-success">Activo</span>{{else}}<span class="badge bg-danger">Inactivo</span>{{/if}}</td>
                <td class="small text-muted">{{formatDate this.createdAt}}</td>
                <td class="table-actions">
                  {{#if (eq this.id ../session.userId)}}
                    <span class="text-muted small">—</span>
                  {{else}}
                    {{#if this.status}}
                      <form action="/affiliates/user/{{this.id}}/deactivate" method="POST" class="d-inline" onsubmit="return confirm('¿Desactivar este usuario?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Desactivar</button>
                      </form>
                    {{else}}
                      <form action="/affiliates/user/{{this.id}}/activate" method="POST" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-outline-success">Activar</button>
                      </form>
                    {{/if}}
                  {{/if}}
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  {{else}}
    <p class="text-muted">No hay usuarios registrados.</p>
  {{/if}}
{{/if}}
