<div class="container mt-4">
  <a href="/affiliates" class="btn btn-outline-secondary btn-sm mb-3">← Volver al listado</a>

  <h1 class="mb-3">{{affiliate.first_name}} {{affiliate.last_name}}</h1>

  <div class="card">
    <div class="card-body">
      <p class="card-text"><strong>Email:</strong> {{affiliate.email}}</p>
      <p class="card-text"><strong>Membresía:</strong> {{capitalize affiliate.membershipType.name}} ({{affiliate.membershipType.discount}} descuento)</p>
      <p class="card-text">
        <strong>Estado:</strong>
        {{#if affiliate.status}}
          <span class="badge bg-success">Activo</span>
        {{else}}
          <span class="badge bg-danger">Inactivo</span>
        {{/if}}
      </p>
      <p class="card-text"><strong>Creado:</strong> {{affiliate.createdAt}}</p>
    </div>
  </div>

  <div class="mt-3 d-flex gap-2">
    <a href="/affiliates/{{affiliate.id}}/edit" class="btn btn-warning">Editar</a>
    {{#if affiliate.status}}
      <form action="/affiliates/{{affiliate.id}}/deactivate" method="POST">
        <button type="submit" class="btn btn-danger">Desactivar</button>
      </form>
    {{else}}
      <form action="/affiliates/{{affiliate.id}}/activate" method="POST">
        <button type="submit" class="btn btn-success">Activar</button>
      </form>
    {{/if}}
  </div>
</div>
