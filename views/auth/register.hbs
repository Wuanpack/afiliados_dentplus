
<div class="row justify-content-center">
  <div class="col-md-5 col-lg-4">
    <h1 class="h3 mb-4">Crear cuenta</h1>
    {{#if error}}
      <div class="alert alert-danger">{{error}}</div>
    {{/if}}
    <form action="/login/register" method="POST" class="card card-body shadow-sm" novalidate>
      <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <input type="email" id="email" name="email" class="form-control{{#if errors.email}} is-invalid{{/if}}" value="{{values.email}}">
        {{#if errors.email}}<div class="invalid-feedback">{{errors.email}}</div>{{/if}}
      </div>
      <div class="mb-3">
        <label for="password" class="form-label">Contraseña</label>
        <input type="password" id="password" name="password" class="form-control{{#if errors.password}} is-invalid{{/if}}" minlength="8">
        {{#if errors.password}}<div class="invalid-feedback">{{errors.password}}</div>{{/if}}
        <div class="form-text">Mínimo 8 caracteres.</div>
      </div>
      <button type="submit" class="btn btn-success w-100">Crear cuenta</button>
    </form>
    <p class="mt-3 text-center text-muted small">
      ¿Ya tienes cuenta? <a href="/login">Inicia sesión</a>
    </p>
  </div>
</div>
